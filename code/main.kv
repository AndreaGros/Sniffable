# sniffer.kv
<CommonNavigationRailItem>:
    on_active: if self.active: app.switch_screen(self.screen_to_open)
    MDNavigationRailItemIcon:
        icon: root.icon

    

<SnifferScreen>:
    MDBoxLayout:
        orientation: "vertical"
        spacing: 0
        # ── COLUMN HEADERS ───────────────────────────────────────────
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "28dp"
            padding: "8dp", "4dp"
            spacing: "8dp"
            md_bg_color: app.theme_cls.surfaceContainerHighColor

            MDLabel:
                text: "#"
                font_style: "Label"
                role: "small"
                bold: True
                size_hint_x: None
                width: "36dp"
                halign: "right"
                theme_text_color: "Secondary"

            MDBoxLayout:
                size_hint_x: None
                width: "1dp"

            MDLabel:
                text: "Time"
                font_style: "Label"
                role: "small"
                bold: True
                size_hint_x: None
                width: "76dp"
                theme_text_color: "Secondary"

            MDBoxLayout:
                size_hint_x: None
                width: "1dp"

            MDLabel:
                text: "Source"
                font_style: "Label"
                role: "small"
                bold: True
                size_hint_x: None
                width: "120dp"
                theme_text_color: "Secondary"

            MDBoxLayout:
                size_hint_x: None
                width: "1dp"

            MDLabel:
                text: "Destination"
                font_style: "Label"
                role: "small"
                bold: True
                size_hint_x: None
                width: "120dp"
                theme_text_color: "Secondary"

            MDBoxLayout:
                size_hint_x: None
                width: "1dp"

            MDLabel:
                text: "Proto"
                font_style: "Label"
                role: "small"
                bold: True
                size_hint_x: None
                width: "52dp"
                halign: "center"
                theme_text_color: "Secondary"

            MDBoxLayout:
                size_hint_x: None
                width: "1dp"

            MDLabel:
                text: "Len"
                font_style: "Label"
                role: "small"
                bold: True
                size_hint_x: None
                width: "52dp"
                halign: "right"
                theme_text_color: "Secondary"

            MDBoxLayout:
                size_hint_x: None
                width: "1dp"

            MDLabel:
                text: "Info"
                font_style: "Label"
                role: "small"
                bold: True
                theme_text_color: "Secondary"
        
        # ── PACKETS ───────────────────────────────────────────
        RecycleView:
            id: packet_list
            viewclass: "PacketRow"
            do_scroll_x: False

            RecycleBoxLayout:
                orientation: "vertical"
                default_size_hint: 1, None
                default_size: 0, "40dp"
                size_hint_y: None
                height: self.minimum_height

        
        # ── BUTTONS BAR ──────────────────────────────────────────────────
        MDBoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "56dp"
            padding: "16dp", "8dp"
            spacing: "12dp"
            md_bg_color: app.theme_cls.surfaceContainerColor

            MDButton:
                style: "text"
                size_hint_x: None
                width: "72dp"
                on_release: root.clear()
                MDButtonText:
                    text: "Clear"
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.errorColor

            MDButton:
                id: start_stop_btn
                style: "filled"
                size_hint_x: None
                width: "100dp"
                theme_bg_color: "Custom"
                on_release: root.start_sniffer() if not root.capturing else root.stop_sniffer()
                md_bg_color:
                    app.theme_cls.errorColor if root.capturing else \
                    app.theme_cls.primaryColor

                MDButtonText:
                    id: start_stop_label
                    text: "Start" if not root.capturing else "Stop"
                    theme_text_color: "Custom"
                    text_color: (1, 1, 1, 1)

<PacketRow>:
    orientation: "horizontal"
    size_hint_y: None
    height: "40dp"

    MDLabel:
        text: root.index

    MDLabel:
        text: root.src_ip

    MDLabel:
        text: root.dst_ip

    MDLabel:
        text: root.protocol

    MDLabel:
        text: root.length

    MDLabel:
        text: root.info

<SenderScreen>
    MDBoxLayout:
        orientation: "vertical"
        spacing: 0

        # ── SEND BAR ─────────────────────────────────────────────────
        MDBoxLayout:
            id: send_bar
            orientation: "horizontal"
            size_hint_y: None
            height: "56dp"
            padding: "16dp", "8dp"
            spacing: "12dp"
            md_bg_color: app.theme_cls.surfaceContainerColor

            MDLabel:
                id: send_status
                text: "Ready"
                font_style: "Body"
                role: "medium"
                theme_text_color: "Secondary"

            MDButton:
                style: "text"
                size_hint_x: None
                width: "80dp"
                MDButtonText:
                    text: "Clear"
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.errorColor

            MDButton:
                id: send_btn
                style: "filled"
                size_hint_x: None
                width: "110dp"
                theme_bg_color: "Custom"
                md_bg_color: app.theme_cls.primaryColor

                MDButtonText:
                    text: "  Send"
                    theme_text_color: "Custom"

            

        
MDBoxLayout:
    md_bg_color: self.theme_cls.backgroundColor
    MDNavigationRail:
        md_bg_color: "lightgray"
        theme_bg_color: "Custom"
        type: "unselected"
        CommonNavigationRailItem:
            icon: "wifi"
            screen_to_open: 'sniffer'
            on_release: app.switch_screen(self.screen_to_open)

        CommonNavigationRailItem:
            icon: "package-variant"
            screen_to_open: 'sender'
            on_release: app.switch_screen(self.screen_to_open)


    MDScreenManager:
        id: screen_manager

        SnifferScreen:
            name: "sniffer"
            md_bg_color: self.theme_cls.backgroundColor

        SenderScreen:
            name: "sender"
            md_bg_color: self.theme_cls.backgroundColor