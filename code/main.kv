<CommonNavigationRailItem>:
    on_active: if self.active: app.switch_screen(self.screen_to_open)
    MDNavigationRailItemIcon:
        icon: root.icon

<SnifferScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: "12dp"
        spacing: "12dp"
        md_bg_color: app.theme_cls.backgroundColor

        # ── HEADER CARD (Contiene i titoli delle colonne) ──────────────
        MDCard:
            size_hint_y: None
            height: "48dp"
            padding: "12dp", 0
            radius: [12, 12, 4, 4]
            md_bg_color: app.theme_cls.surfaceContainerHighColor
            elevation: 1
            style: "filled"

            MDBoxLayout:
                orientation: "horizontal"
                spacing: "8dp"
                vertical_center: True

                MDLabel:
                    text: "#"
                    size_hint_x: None
                    width: "36dp"
                    halign: "right"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Time"
                    size_hint_x: None
                    width: "80dp"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Source"
                    size_hint_x: None
                    width: "130dp"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Destination"
                    size_hint_x: None
                    width: "130dp"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Proto"
                    size_hint_x: None
                    width: "60dp"
                    halign: "center"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Len"
                    size_hint_x: None
                    width: "52dp"
                    halign: "right"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

                MDLabel:
                    text: "Info"
                    font_style: "Label"
                    role: "large"
                    bold: True
                    theme_text_color: "Secondary"

        # ── PACKETS LIST ───────────────────────────────────────────
        MDCard:
            radius: [4, 4, 12, 12]
            elevation: 1
            padding: "4dp"
            style: "filled"
            md_bg_color: app.theme_cls.surfaceContainerLowColor

            RecycleView:
                id: packet_list
                viewclass: "PacketRow"
                always_overscroll: False
                RecycleBoxLayout:
                    orientation: "vertical"
                    default_size: None, "44dp"
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    padding: "4dp"
                    spacing: "2dp"

        # ── CONTROL BAR ──────────────────────────────────────────────────
        MDCard:
            size_hint_y: None
            height: "72dp"
            padding: "16dp", "8dp"
            radius: 16
            elevation: 2
            md_bg_color: app.theme_cls.surfaceContainerColor
            style: "filled"

            MDBoxLayout:
                orientation: "horizontal"
                spacing: "12dp"
                adaptive_width: True
                pos_hint: {"center_y": .5}

                MDButton:
                    id: start_stop_btn
                    style: "filled"
                    on_release: root.start_sniffer() if not root.capturing else root.stop_sniffer()
                    theme_bg_color: "Custom"
                    md_bg_color: app.theme_cls.errorColor if root.capturing else app.theme_cls.primaryColor
                    
                    MDButtonIcon:
                        icon: "play" if not root.capturing else "stop"
                    MDButtonText:
                        id: start_stop_label
                        text: "Start" if not root.capturing else "Stop"

                MDButton:
                    style: "tonal"
                    on_release: root.clear()
                    MDButtonIcon:
                        icon: "delete-outline"
                    MDButtonText:
                        text: "Clear"

                # Divider
                MDWidget:
                    size_hint_x: None
                    width: "24dp"

                MDButton:
                    id: TCP_filter
                    style: "filled" if "tcp" in root.filters else "outlined"
                    on_release: root.add_remove_filter("tcp")
                    MDButtonText:
                        text: "TCP"

                MDButton:
                    id: UDP_filter
                    style: "filled" if "udp" in root.filters else "outlined"
                    on_release: root.add_remove_filter("udp")
                    MDButtonText:
                        text: "UDP"

<PacketRow>:
    orientation: "horizontal"
    size_hint_y: None
    height: "40dp"
    padding: "8dp", 0
    spacing: "8dp"
    canvas.before:
        Color:
            rgba: (1, 1, 1, 0.05) if root.index and int(root.index) % 2 == 0 else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [6,]

    MDLabel:
        text: root.index
        size_hint_x: None
        width: "36dp"
        halign: "right"
        font_style: "Body"
        role: "small"

    MDLabel:
        text: root.timestamp
        size_hint_x: None
        width: "80dp"
        font_style: "Body"
        role: "small"
        theme_text_color: "Secondary"

    MDLabel:
        text: root.src_ip
        size_hint_x: None
        width: "130dp"
        font_style: "Body"
        role: "small"
        theme_text_color: "Custom"
        text_color: "#4CAF50" # Verde più moderno

    MDLabel:
        text: root.dst_ip
        size_hint_x: None
        width: "130dp"
        font_style: "Body"
        role: "small"
        theme_text_color: "Custom"
        text_color: "#F44336" # Rosso più armonioso

    MDLabel:
        text: root.protocol
        size_hint_x: None
        width: "60dp"
        halign: "center"
        font_style: "Label"
        role: "large"
        theme_text_color: "Custom"
        text_color: "#FF9800"

    MDLabel:
        text: root.length
        size_hint_x: None
        width: "52dp"
        halign: "right"
        font_style: "Body"
        role: "small"

    MDLabel:
        text: root.info
        font_style: "Body"
        role: "small"
        shorten: True
        shorten_from: "right"

<InfoPacketScreen>
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        MDTopAppBar:
            type: "small"
            md_bg_color: app.theme_cls.surfaceContainerColor
            
            MDTopAppBarLeadingButtonContainer:
                MDActionTopAppBarButton:
                    icon: "arrow-left"
                    on_release: app.switch_screen("sniffer")
            
            MDTopAppBarTitle:
                text: "Packet Detail"
                pos_hint: {"center_x": .5}

        ScrollView:
            MDBoxLayout:
                id: layer_container
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: "16dp"
                spacing: "12dp"

<SenderScreen>
    MDBoxLayout:
        orientation: "vertical"
        padding: "16dp"
        spacing: "16dp"
        md_bg_color: app.theme_cls.backgroundColor

        MDCard:
            orientation: "vertical"
            padding: "16dp"
            radius: 16
            elevation: 1
            style: "filled"
            md_bg_color: app.theme_cls.surfaceContainerColor
            
            MDLabel:
                text: "Packet Generator"
                font_style: "Headline"
                role: "small"
                adaptive_height: True

            MDWidget: # Spacer

        MDCard:
            size_hint_y: None
            height: "80dp"
            padding: "16dp"
            radius: 16
            elevation: 2
            style: "filled"
            md_bg_color: app.theme_cls.surfaceContainerHighColor

            MDBoxLayout:
                orientation: "horizontal"
                spacing: "12dp"
                vertical_center: True

                MDIcon:
                    icon: "information-outline"
                    theme_text_color: "Secondary"

                MDLabel:
                    id: send_status
                    text: "Ready to send"
                    font_style: "Body"
                    role: "large"

                MDButton:
                    style: "text"
                    MDButtonText:
                        text: "Clear"
                        theme_text_color: "Custom"
                        text_color: app.theme_cls.errorColor

                MDButton:
                    id: send_btn
                    style: "filled"
                    MDButtonIcon:
                        icon: "send"
                    MDButtonText:
                        text: "Send"

MDBoxLayout:
    md_bg_color: app.theme_cls.backgroundColor
    
    MDNavigationRail:
        type: "selected"
        md_bg_color: app.theme_cls.surfaceContainerLowColor
        
        CommonNavigationRailItem:
            icon: "wifi"
            screen_to_open: 'sniffer'
        
        CommonNavigationRailItem:
            icon: "package-variant"
            screen_to_open: 'sender'

    MDScreenManager:
        id: screen_manager
        SnifferScreen:
            name: "sniffer"
        InfoPacketScreen:
            name: "info"
        SenderScreen:
            name: "sender"