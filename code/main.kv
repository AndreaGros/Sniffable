# sniffer.kv
<CommonNavigationRailItem>
    on_release: app.switch_screen(self.screen_to_open)
    MDNavigationRailItemIcon:
        icon: root.icon
        disabled: True
    MDNavigationRailItemLabel:
        text: root.text

    

<SnifferScreen>:
    MDLabel:
        text: "Label"
        color: "green"

<SenderScreen>
    MDLabel:
        text: "Label"
        color: "red"

        
MDBoxLayout:

    MDNavigationRail:
        type: "unselected"
        CommonNavigationRailItem:
            icon: "wifi"
            text: "Files"
            screen_to_open: 'sniffer'

        CommonNavigationRailItem:
            icon: "package-variant"
            text: "Bookmark"
            screen_to_open: 'sender'


    MDScreenManager:
        id: screen_manager

        SnifferScreen:
            name: "sniffer"
            md_bg_color: self.theme_cls.backgroundColor

        SenderScreen:
            name: "sender"
            md_bg_color: self.theme_cls.backgroundColor