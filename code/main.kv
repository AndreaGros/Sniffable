# sniffer.kv
MDScreenManager:
    MenuScreen:
    SnifferScreen:

<MenuScreen>:
    name: "menu"
    md_bg_color: self.theme_cls.backgroundColor
    MDBoxLayout:
        orientation: 'vertical'
        padding: "20dp"
        pos_hint: {"center_x": .5, "center_y": .5}
        MDFabButton:
            icon: "wifi"
            style: "large"
        MDFabButton:
            icon: "package-variant"
            style: "large"
        