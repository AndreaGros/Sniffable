# sniffer.kv
<CommonNavigationRailItem>
    MDNavigationRailItemIcon:
        icon: root.icon
        on_item_press: app.switch_screen(root.screen_to_open)

    MDNavigationRailItemLabel:
        text: root.text
    

<SnifferScreen>:
    MDButton:
        style: "elevated"
        text: "Elevated"

<SenderScreen>
    MDLabel:
        text: "Label"
        color:  "red"

        
MDBoxLayout:

    MDNavigationRail:
        type: "unselected"

        CommonNavigationRailItem:
            icon: "wifi"
            text: "Files"
            screen_to_open: "sniffer"

        CommonNavigationRailItem:
            icon: "package-variant"
            text: "Bookmark"
            screen_to_open: "sender"


    MDScreenManager:
        id: screen_manager

        SnifferScreen:
            name: "sniffer"
            md_bg_color: self.theme_cls.backgroundColor

        SenderScreen:
            name: "sender"
            md_bg_color: "black"
        

